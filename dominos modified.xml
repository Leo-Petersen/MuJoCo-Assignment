<mujoco model="growing dominos">

  <option cone="elliptic" impratio="10" sleep_tolerance="3e-4">
    <flag sleep="enable"/>
  </option>

  <worldbody>
    <light pos="5 0 10" diffuse="1 1 1"/>
    <geom type="plane" size="20 20 .01" pos="5 0 1e-6"/>

    <!-- starter: tilted 10 deg, same size as domino 1 -->
    <body pos="-.15 0 .089" euler="0 10 0">
      <freejoint/>
      <geom type="box" size=".008 .044 .089" density="360"/>
    </body>

    <!-- domino 1: scale 1.0x, full height 0.178 m -->
    <body pos="0.0 0 .089">
      <freejoint/>
      <geom type="box" size=".008 .044 .089" density="360"/>
    </body>

    <!-- domino 2: scale 1.5x, full height 0.267 m, gap = 50% of domino 1 height -->
    <body pos="0.109 0 .134">
      <freejoint/>
      <geom type="box" size=".012 .066 .134" density="360"/>
    </body>

    <!-- domino 3: scale 2.25x, full height 0.400 m, gap = 50% of domino 2 height -->
    <body pos="0.273 0 .200">
      <freejoint/>
      <geom type="box" size=".018 .099 .200" density="360"/>
    </body>

    <!-- domino 4: scale 3.375x, full height 0.601 m, gap = 50% of domino 3 height -->
    <body pos="0.518 0 .300">
      <freejoint/>
      <geom type="box" size=".027 .149 .300" density="360"/>
    </body>

    <!-- domino 5: scale 5.06x, full height 0.901 m, gap = 50% of domino 4 height -->
    <body pos="0.886 0 .451">
      <freejoint/>
      <geom type="box" size=".041 .223 .451" density="360"/>
    </body>

    <!-- domino 6: scale 7.59x, full height 1.352 m, gap = 50% of domino 5 height -->
    <body pos="1.437 0 .676">
      <freejoint/>
      <geom type="box" size=".061 .334 .676" density="360"/>
    </body>

    <!-- domino 7: scale 11.4x, full height 2.028 m, gap = 50% of domino 6 height -->
    <body pos="2.265 0 1.014">
      <freejoint/>
      <geom type="box" size=".091 .501 1.014" density="360"/>
    </body>

    <!-- domino 8: scale 17.1x, full height 3.041 m, gap = 50% of domino 7 height -->
    <body pos="3.507 0 1.521">
      <freejoint/>
      <geom type="box" size=".137 .752 1.521" density="360"/>
    </body>

    <!-- domino 9: scale 25.6x, full height 4.562 m, gap = 50% of domino 8 height -->
    <body pos="5.369 0 2.281">
      <freejoint/>
      <geom type="box" size=".205 1.128 2.281" density="360"/>
    </body>

    <!-- domino 10: scale 38.4x, full height 6.843 m, gap = 50% of domino 9 height -->
    <body pos="8.163 0 3.422">
      <freejoint/>
      <geom type="box" size=".308 1.692 3.422" density="360"/>
    </body>

  </worldbody>

</mujoco>